@model IEnumerable<SistemaReservas.Core.Entities.Sede>
@{ ViewData["Title"] = "Nuestras Sedes y Apartamentos"; }

<h2>@ViewData["Title"]</h2>
<hr />
<div class="row">
    @foreach (var sede in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title text-primary">@sede.Nombre</h5>
                    <h6 class="card-subtitle mb-2 text-muted">@sede.Ciudad, @sede.Departamento</h6>
                    <p class="card-text">@sede.Descripcion</p>
                    <p class="card-text"><small class="text-muted">Capacidad Total: @sede.CapacidadTotal personas</small></p>
                </div>
            </div>
        </div>
    }
</div>
