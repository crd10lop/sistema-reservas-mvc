@model IEnumerable<SistemaReservas.Core.Entities.Reserva>
@{ ViewData["Title"] = "Mis Reservas"; }

<h2>Historial de Reservas</h2>
<hr />

@if (!Model.Any())
{
    <div class="alert alert-info">Aún no tienes reservas en el sistema. <a asp-action="BuscarDisponibilidad">¡Reserva ahora!</a></div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>ID Reserva</th>
                    <th>Fechas</th>
                    <th>Sede y Alojamiento</th>
                    <th>Estado</th>
                    <th>Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reserva in Model)
                {
                    <tr>
                        <td>#@reserva.Id</td>
                        <td>@reserva.FechaInicio.ToShortDateString() al @reserva.FechaFin.ToShortDateString()</td>
                        <td>
                            @foreach (var detalle in reserva.DetallesReserva)
                            {
                                <div><strong>@detalle.Alojamiento.Sede.Nombre</strong> - @detalle.Alojamiento.Nombre</div>
                            }
                        </td>
                        <td>
                            <span class="badge @(reserva.Estado == SistemaReservas.Core.Enums.EstadoReserva.Pendiente ? "bg-warning text-dark" : "bg-success")">
                                @reserva.Estado.ToString()
                            </span>
                        </td>
                        <td class="fw-bold">@reserva.TotalReserva.ToString("C0")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
